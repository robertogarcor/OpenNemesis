# OpenNemesis - Configuración de Variables de Entorno

# Telegram Bot
TELEGRAM_BOT_TOKEN=
# ID de usuario autorizado (opcional, dejar vacío para permitir cualquier usuario)
TELEGRAM_ALLOWED_USER_ID=
MAX_HISTORY_MESSAGES=50
PERSISTENCE_ENABLED=true

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# GOG CLI (Google Workspace)
GOG_ACCOUNT=
GOGCLI_PATH=bin/gogcli
